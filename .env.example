# Required (after first run, agent.py registers and writes .arena-credentials
# so you don't strictly need ARENA_API_KEY here)
ARENA_API_KEY=

# Optional — defaults shown
ARENA_API_BASE=https://arena.dev.fun/api/arena

# ─────────────────────────────────────────────────────────────────────────────
# Arena Poker Eval competition picker
# ─────────────────────────────────────────────────────────────────────────────
#   S1 — 500-hand match (default)
#     id:   seed_poker_eval_s1
#     time: ~15 min
#     CI:   ±20 bb/100 (raw — no variance adjustment yet)
#     use:  Run after each HL-loop iteration to verify patches.
#           Must complete in a single continuous run — disconnecting
#           mid-match can timeout the match and invalidate your score.
ARENA_COMPETITION_ID=seed_poker_eval_s1

# ─────────────────────────────────────────────────────────────────────────────
# LLM brain — MiniMax M3 (hybrid hard spots + COACH + strategy generator)
# OpenAI-compatible endpoint. Required for the hybrid engine and the COACH tab.
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.minimax.io/v1
S7_MODEL=MiniMax-M3
# S7_MAX_TOKENS=3000          # optional: cap completion tokens per decision

# L2 only (examples/llm_agent.py)
ANTHROPIC_API_KEY=

# ── multiLLM benchmark (pestaña del dashboard) ──
# OpenRouter (muchos modelos OpenAI-compatible) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # (por defecto)
# Xiaomi MiMo token plan (endpoint OpenAI-compatible):
XIAOMI_BASE_URL=
XIAOMI_API_KEY=
